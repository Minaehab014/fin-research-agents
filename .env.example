# SEC EDGAR - required for filing ingestion
# Format: "Your Name - your@email.com"
SEC_USER_AGENT="Your Name - your@email.com"

# Groq - LLM inference (https://console.groq.com)
GROQ_API_KEY="gsk_..."

# NewsAPI - market news headlines (https://newsapi.org)
NEWSAPI_KEY="your_newsapi_key"

# Hugging Face - sentence-transformers embeddings (https://huggingface.co/settings/tokens)
HF_TOKEN="hf_..."
